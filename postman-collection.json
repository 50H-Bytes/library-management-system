{
  "info": {
    "name": "Library Management System API",
    "description": "REST API for Online Library Management System",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Members",
      "item": [
        {
          "name": "Get All Members",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/members"
          }
        },
        {
          "name": "Get Member by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/members/1"
          }
        },
        {
          "name": "Create Member",
          "request": {
            "method": "POST",
            "header": [{
              "key": "Content-Type",
              "value": "application/json"
            }],
            "url": "{{baseUrl}}/api/members",
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\":\"John\",\"lastName\":\"Doe\",\"email\":\"john@example.com\",\"phone\":\"123-456-7890\"}"
            }
          }
        },
        {
          "name": "Update Member",
          "request": {
            "method": "PUT",
            "header": [{
              "key": "Content-Type",
              "value": "application/json"
            }],
            "url": "{{baseUrl}}/api/members/1",
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"inactive\"}"
            }
          }
        },
        {
          "name": "Delete Member",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/members/1"
          }
        }
      ]
    },
